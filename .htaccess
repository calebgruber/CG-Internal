# Root .htaccess
# Requires mod_rewrite and mod_headers

Options -Indexes -MultiViews
ServerSignature Off

# ── Security headers ────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # Uncomment in production when TLS is confirmed:
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Block access to sensitive files and directories ─────
<FilesMatch "\.(sql|sh|env|log|json|lock|md|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct HTTP access to shared/ and db/ subdirectories.
# <DirectoryMatch> is NOT valid in .htaccess; use RewriteRule instead.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to shared/ and db/ directories
    RewriteRule ^(shared|db)(/|$) - [F,L]

    # 1. Redirect requests WITH .php extension → extensionless (canonical URLs)
    #    Skip this for real directories and for the rewrite loop guard
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # 2. Internally rewrite extensionless URLs → .php (if the .php file exists)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ /$1.php [L,QSA]
</IfModule>

# ── Default index files ──────────────────────────────────
DirectoryIndex index.php index.html
